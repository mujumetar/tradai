{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/live-prices",
      "destination": "/api/live-prices.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    },
    "api/live-prices.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/update-prices",
      "schedule": "* * * * *"
    }
  ]
}
