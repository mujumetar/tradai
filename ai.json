    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst BOT_TOKEN = '8692399523:AAHcIwKdlY3K0oQedvqk3Uck5JNEm3JyyQ4';\nlet out = { source: 'unknown', userId: null, chatId: null, userMessage: '', symbol: 'NIFTY', market: 'NSE', userLanguage: 'English', langCode: 'en', intent: 'chat', firstName: 'Trader', botToken: BOT_TOKEN };\nif (item.message || item.callback_query) {\n  const msg = item.message || item.callback_query?.message;\n  const text = (item.message?.text || item.callback_query?.data || '').trim();\n  out.source = 'telegram'; out.userId = String(msg.from.id); out.chatId = String(msg.chat.id); out.firstName = msg.from.first_name || 'Trader'; out.userMessage = text;\n  const langs = { '/setlang hindi':{lc:'hi',ul:'Hindi'}, '/setlang gujarati':{lc:'gu',ul:'Gujarati'}, '/setlang marathi':{lc:'mr',ul:'Marathi'}, '/setlang tamil':{lc:'ta',ul:'Tamil'} };\n  for(const[cmd,info] of Object.entries(langs)) if(text.toLowerCase().startsWith(cmd)){ out.intent='set_language'; out.langCode=info.lc; out.userLanguage=info.ul; }\n  if (text.startsWith('/tip')) { out.intent='tip'; const p=text.split(' '); if(p[1])out.symbol=p[1].toUpperCase(); }\n  else if (text.startsWith('/chart')) { out.intent='chart'; }\n  else if (text.startsWith('/scan')) { out.intent='auto_scan'; }\n  else if (text.startsWith('/help')) { out.intent='help'; }\n  else if (text.startsWith('/start')) { out.intent='start'; }\n  const symPat = /\\b(NIFTY|BANKNIFTY|RELIANCE|TCS|BTCUSDT|GOLD)\\b/i;\n  const sm = text.match(symPat); if(sm && out.intent==='chat'){ out.symbol=sm[1].toUpperCase(); out.intent='tip'; }\n} else if(item.symbol) { out.source='webhook'; out.symbol=String(item.symbol).toUpperCase(); out.intent='auto_scan'; out.chatId=item.chatId||''; }\nreturn [{json:out}];"
      },
