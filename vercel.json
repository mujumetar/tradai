{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/live-prices",
      "destination": "/api/live-prices.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/update-prices",
      "schedule": "* * * * *"
    }
  ]
}