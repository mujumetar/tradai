{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/live-prices",
      "destination": "/api/live-prices.cjs"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.cjs"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/update-prices",
      "schedule": "* * * * *"
    }
  ],
  "functions": {
    "api/*.cjs": {
      "maxDuration": 30
    }
  }
}
